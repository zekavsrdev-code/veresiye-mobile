# Public runtime config for the Expo app. Copy to `.env` and adjust.
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time (never put secrets here).

# Backend API base URL (must end with /api).
# - iOS simulator / Android emulator: localhost loopback works as-is.
# - Physical device: set to your machine's LAN IP, e.g. http://192.168.1.20:8000/api
EXPO_PUBLIC_API_URL=http://10.111.231.64:8000/api
